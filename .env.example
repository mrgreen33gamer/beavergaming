# Server-only. Copy to .env.local — never commit real secrets.

# --- Database -------------------------------------------------------------
# From Scott Applications Atlas cluster (use a dedicated beavergaming DB).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/
MONGODB_DB=beavergaming

# --- Email (SMTP2GO) ------------------------------------------------------
# Used for account verification and password resets. If these are unset,
# registration still works and the send is skipped with a console warning.
SMTP2GO_API_KEY=
FROM_EMAIL=contact@scottapps.com

# Absolute base URL used to build links in emails (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://beavergaming.vercel.app

# --- Card art generation (local only) -------------------------------------
# Only needed to run `npm run gen:cards`. Never read at build or runtime, so
# this does NOT need to be set in Vercel.
XAI_API_KEY=
